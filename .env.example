# Your admin password — set this to anything you want
ADMIN_PASSWORD=your-secret-password

# Vercel KV (auto-populated when you link a KV store in the Vercel dashboard)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
